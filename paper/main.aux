\newlabel{fig:harmonic_hires}{{6a}{105}{Raw harmonic landscape: $\log _{10}$ spectral power of $\mathrm {rgb\_cmy\_imbalance}(t)$ across $\omega \in (0,\pi )$ at $N{=}150$ resolution. Coloured dots mark the theoretical frequency series ($f_\mathrm {zitt}$, $f_\mathrm {vacuum}$, $f_\mathrm {beat}$, $f_\mathrm {2nd}$, $f_\mathrm {3rd}$); white-fill stars mark the 2:1, 3:1, and 4:1 lock-in points where band-crossings occur. See Fig.~\ref {fig:dirac_cones} for the same data with Dirac-cone annotations overlaid}{figure.caption.147}{}}
\newlabel{sub@fig:harmonic_hires}{{a}{105}{Raw harmonic landscape: $\log _{10}$ spectral power of $\mathrm {rgb\_cmy\_imbalance}(t)$ across $\omega \in (0,\pi )$ at $N{=}150$ resolution. Coloured dots mark the theoretical frequency series ($f_\mathrm {zitt}$, $f_\mathrm {vacuum}$, $f_\mathrm {beat}$, $f_\mathrm {2nd}$, $f_\mathrm {3rd}$); white-fill stars mark the 2:1, 3:1, and 4:1 lock-in points where band-crossings occur. See Fig.~\ref {fig:dirac_cones} for the same data with Dirac-cone annotations overlaid}{figure.caption.147}{}}
\newlabel{fig:dirac_cones}{{6b}{105}{Dirac-cone annotation of the same heatmap as Fig.~\ref {fig:harmonic_hires}: at each Arnold-tongue lock-in (2:1, 3:1, 4:1), two dispersion lines cross linearly --- a Dirac-cone band crossing. The graphene K-point (inset, top right) has the same local $E \propto |k|$ structure. Mass quantization on the lattice and the spin-$\tfrac {1}{2}$ Dirac-point physics of graphene therefore share a single band-crossing mechanism, not a coincidence of formulas}{figure.caption.147}{}}
\newlabel{sub@fig:dirac_cones}{{b}{105}{Dirac-cone annotation of the same heatmap as Fig.~\ref {fig:harmonic_hires}: at each Arnold-tongue lock-in (2:1, 3:1, 4:1), two dispersion lines cross linearly --- a Dirac-cone band crossing. The graphene K-point (inset, top right) has the same local $E \propto |k|$ structure. Mass quantization on the lattice and the spin-$\tfrac {1}{2}$ Dirac-point physics of graphene therefore share a single band-crossing mechanism, not a coincidence of formulas}{figure.caption.147}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Harmonic fingerprint of the $\mathcal  {T}_\diamond ^3$ lattice. \textbf  {Left:} the raw spectral power across the instruction-frequency scan, with theoretical frequency markers. \textbf  {Right:} Dirac-cone annotation showing each Arnold-tongue lock-in as a linear band crossing, paralleling the spin-$\tfrac  {1}{2}$ Dirac point of graphene. Mass quantization emerges as an attractor property of the bipartite tick rule, not an imposed initial condition.}}{105}{figure.caption.147}\protected@file@percent }
