\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Causal cone structure as a function of mass and phase map (\texttt  {exp\_00}).} \textbf  {Left:} fraction of total amplitude vs.\ radius at tick 8 for three values of the mass parameter $\omega $. A photon ($\omega =0$, $p_\mathrm  {stay}=0$) leaves all amplitude at the cone boundary (yellow): every tick is a strict hop. A light mass ($\omega =1$, $p_\mathrm  {stay}\approx 0.23$) and a massive session ($\omega =2$, $p_\mathrm  {stay}\approx 0.71$) increasingly retain amplitude near the centre, giving the bipartite-lattice realisation of the rest-frame Zitterbewegung. The cone boundary $r{=}8$ at tick~8 is the topological speed limit $c=1$ hop/tick. \textbf  {Right:} the same cone modified by a uniform phase map $k_x = 0.3$. The phase gradient breaks the RGB/CMY symmetry of the hop directions, tilting the cone toward $+x$ --- exactly the lattice realisation of momentum as gauge-transformed advancement (\S  \ref {subsec:gauge}).}}{26}{figure.caption.14}\protected@file@percent }
\newlabel{fig:cone_structure}{{4}{26}{\textbf {Causal cone structure as a function of mass and phase map (\texttt {exp\_00}).} \textbf {Left:} fraction of total amplitude vs.\ radius at tick 8 for three values of the mass parameter $\omega $. A photon ($\omega =0$, $p_\mathrm {stay}=0$) leaves all amplitude at the cone boundary (yellow): every tick is a strict hop. A light mass ($\omega =1$, $p_\mathrm {stay}\approx 0.23$) and a massive session ($\omega =2$, $p_\mathrm {stay}\approx 0.71$) increasingly retain amplitude near the centre, giving the bipartite-lattice realisation of the rest-frame Zitterbewegung. The cone boundary $r{=}8$ at tick~8 is the topological speed limit $c=1$ hop/tick. \textbf {Right:} the same cone modified by a uniform phase map $k_x = 0.3$. The phase gradient breaks the RGB/CMY symmetry of the hop directions, tilting the cone toward $+x$ --- exactly the lattice realisation of momentum as gauge-transformed advancement (\S \ref {subsec:gauge})}{figure.caption.14}{}}
