\@writefile{toc}{\contentsline {paragraph}{Experiment \texttt  {exp\_12}.}{102}{section*.139}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces \textbf  {Two-body hydrogen recovers the Bohr quantization to four significant figures (\texttt  {exp\_12}).} Epoch score (lower is better) as a function of the electron's initial phase gradient $k$, comparing the fixed-well scan (\texttt  {exp\_11}, navy) against the live-proton two-body scan (\texttt  {exp\_12}, dark red). Shaded bands give one epoch-standard-deviation. The teal dashed line marks the analytic prediction $k_\text  {Bohr} = 1/R_1 = 0.0971$. The fixed-well minimum sits at $k_\text  {min} = 0.0900$ ($7.3\%$ below Bohr), with a broad noisy basin. Adding a live proton session shifts the minimum to $k_\text  {min} = 0.0970$, matching $k_\text  {Bohr}$ to $0.09\%$, and tightens the basin. The remaining discrepancy is at the level of the scan resolution $\Delta k = 0.003$ (teal band). Compare with the fixed-well landscape of Fig.~\ref {fig:quantization_scan}.}}{102}{figure.caption.140}\protected@file@percent }
\newlabel{fig:exp12_twobody}{{8}{102}{\textbf {Two-body hydrogen recovers the Bohr quantization to four significant figures (\texttt {exp\_12}).} Epoch score (lower is better) as a function of the electron's initial phase gradient $k$, comparing the fixed-well scan (\texttt {exp\_11}, navy) against the live-proton two-body scan (\texttt {exp\_12}, dark red). Shaded bands give one epoch-standard-deviation. The teal dashed line marks the analytic prediction $k_\text {Bohr} = 1/R_1 = 0.0971$. The fixed-well minimum sits at $k_\text {min} = 0.0900$ ($7.3\%$ below Bohr), with a broad noisy basin. Adding a live proton session shifts the minimum to $k_\text {min} = 0.0970$, matching $k_\text {Bohr}$ to $0.09\%$, and tightens the basin. The remaining discrepancy is at the level of the scan resolution $\Delta k = 0.003$ (teal band). Compare with the fixed-well landscape of Fig.~\ref {fig:quantization_scan}}{figure.caption.140}{}}
